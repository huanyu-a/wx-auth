# 网站地址（必须，微信回调用）
SITE_URL=https://your-site.com

# 微信后台配置（必须）
WECHAT_TOKEN=your-wechat-token

# Session密钥（必须，生产环境用随机字符串）
# 生成命令：openssl rand -hex 32
SESSION_SECRET=dev-secret-change-in-production

# 公众号名称（必须，后端通过 /api/sdk/config 下发给前端 SDK）
WECHAT_NAME=你的公众号名称

# 公众号二维码URL（必须，后端通过 /api/sdk/config 下发给前端 SDK）
WECHAT_QRCODE_URL=https://your-cdn.com/qrcode.jpg

# 微信消息加解密密钥（可选，开启了消息加密才需要）
# WECHAT_AES_KEY=your-wechat-aes-key

# 存储类型（可选，默认JSON，可选：sqlite）
# STORAGE_TYPE=sqlite

# 验证码有效期（可选，默认300秒）
# CODE_EXPIRY=300

# 关键词配置（可选，JSON格式）
# KEYWORDS=["验证码"]
