# ========================================
# 微信订阅号认证系统 - 环境变量配置
# ========================================
# Docker 部署时，私有配置需加 NUXT_ 前缀才能在运行时生效
# 本地开发时直接使用原始名称即可
# ========================================

# ========== 服务端配置（后端部署时需要） ==========

# 网站地址（必须，微信回调用）
NUXT_PUBLIC_SITE_URL=https://your-site.com

# 微信后台配置（必须）
NUXT_WECHAT_TOKEN=your-wechat-token

# Session密钥（必须，生产环境用随机字符串）
# 生成命令：openssl rand -hex 32
NUXT_SESSION_SECRET=dev-secret-change-in-production

# 公众号名称（必须，后端通过 /api/sdk/config 下发给前端 SDK）
NUXT_WECHAT_NAME=神族九帝

# 公众号二维码URL（必须，后端通过 /api/sdk/config 下发给前端 SDK）
NUXT_WECHAT_QRCODE_URL=https://cdn.jsdmirror.com/gh/wu529778790/image@master/blog/qrcode_for_gh_61da24be23ff_258.jpg

# ========== 可选配置 ==========

# 微信消息加解密密钥（可选，开启了消息加密才需要）
# NUXT_WECHAT_AES_KEY=your-wechat-aes-key

# 存储类型（可选，默认JSON，可选：sqlite）
# STORAGE_TYPE=sqlite

# 验证码有效期（可选，默认300秒）
# NUXT_CODE_EXPIRY=300

# 关键词配置（可选，JSON格式）
# NUXT_KEYWORDS=["验证码"]
